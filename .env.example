# ─── Required ─────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs that can talk to the bot.
# Used as a SEED for the runtime whitelist on first startup. After that,
# the list is managed from Telegram via /adduser, /removeuser, /listusers.
# Leave blank on first run to let ANY chat through temporarily.
# Example: ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# Admins can run /adduser, /removeuser, /listusers. Comma-separated chat IDs.
# Blank = first entry from ALLOWED_CHAT_IDS becomes admin.
ADMIN_CHAT_IDS=

# deprecated, use ALLOWED_CHAT_IDS
ALLOWED_CHAT_ID=

# ─── Voice (STT via Groq Whisper, free tier) ──────────────────────────────

# Get a key at https://console.groq.com (free, generous limits).
# Without this, voice notes will be rejected with a friendly message.
GROQ_API_KEY=

# ─── Voice (TTS via ElevenLabs) ───────────────────────────────────────────

# Get a key at https://elevenlabs.io (free tier available).
# Required to enable voice replies. Without these, /voice on will refuse.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# Model ID (default: eleven_multilingual_v2). Other options:
# eleven_turbo_v2_5 (faster, cheaper), eleven_v3 (better quality).
ELEVENLABS_MODEL_ID=eleven_multilingual_v2

# Max characters per voice reply. Longer replies are truncated in voice
# but the full text is also sent as a separate message. Default: 800.
TTS_MAX_CHARS=800

# ─── Preview server (optional, for frontend previews) ────────────────────

# When enabled, the bot starts a small static HTTP server that serves
# workspace/previews/ — use with the `frontend-preview` skill to generate
# a page and get back a clickable URL like http://<HOST>:<PORT>/<slug>/.
#
# PREVIEW_ENABLED=1 turns it on. PREVIEW_HOST is the public IP/domain that
# goes into the URL returned to users — the bot doesn't auto-detect it.
# Port defaults to 8080. Make sure your firewall allows inbound on that port.

PREVIEW_ENABLED=
PREVIEW_HOST=
PREVIEW_PORT=8080

# ─── Video understanding (optional) ───────────────────────────────────────

# Used by the `video-gemini` skill. Get a free key at https://aistudio.google.com/apikey.
# When set, users can send videos and ask the bot to describe/summarize them.
GEMINI_API_KEY=

# ─── WhatsApp bridge (optional, experimental) ─────────────────────────────

# WARNING: the "baileys" provider is a reverse-engineered WhatsApp Web client.
# Use a SECONDARY phone number — WhatsApp may ban numbers for unofficial access.
# Set WHATSAPP_ENABLED=1 to turn it on. On first run the bot prints a QR code
# in the logs; scan it from WhatsApp → Linked devices.

WHATSAPP_ENABLED=
WHATSAPP_PROVIDER=baileys

# Comma-separated phone numbers (digits only, no + or @s.whatsapp.net) that
# can talk to the bot over WhatsApp. Blank = any sender allowed.
# Example: ALLOWED_WHATSAPP_NUMBERS=491234567,15551234567
ALLOWED_WHATSAPP_NUMBERS=

# ─── WhatsApp via Meta Cloud API (official, after business verification) ──

# Switch WHATSAPP_PROVIDER=meta above once you have:
#   1. A verified Meta Business account and a WhatsApp Business app
#   2. A permanent access token (generated in Meta App Dashboard)
#   3. A phone number ID (from the WhatsApp → Getting Started page)
#   4. An HTTPS reverse proxy in front of this bot (Cloudflare Tunnel,
#      nginx + Let's Encrypt, Tailscale Funnel, or similar) — Meta
#      refuses to talk to plain HTTP webhooks.
#
# See docs/GUIDE.md section 3.4 for the full Meta setup walkthrough.

WHATSAPP_META_ACCESS_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=

# Any random string you invent. Paste the same string into Meta App →
# WhatsApp → Configuration → Verify token when subscribing the webhook.
WHATSAPP_META_VERIFY_TOKEN=

# Optional but strongly recommended: Meta App Secret, used to verify the
# X-Hub-Signature-256 header. Without it, anyone who knows your webhook
# URL can forge messages.
WHATSAPP_META_APP_SECRET=

# Local port the bot listens on. Reverse-proxy public HTTPS to this.
# Path defaults to /whatsapp/webhook.
WHATSAPP_META_WEBHOOK_PORT=3001
# WHATSAPP_META_WEBHOOK_PATH=/whatsapp/webhook
# WHATSAPP_META_GRAPH_VERSION=v20.0

# ─── Optional ─────────────────────────────────────────────────────────────

# Log verbosity: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to 'production' to disable pino-pretty and emit JSON logs instead.
# NODE_ENV=production
