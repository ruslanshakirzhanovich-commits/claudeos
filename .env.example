# ─── Required ─────────────────────────────────────────────────────────────

# Telegram bot token from @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=

# Comma-separated list of Telegram chat IDs that can talk to the bot.
# Start the bot, send /chatid from each allowed chat, paste the IDs here.
# Leave blank on first run to let ANY chat through temporarily.
# Example: ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# deprecated, use ALLOWED_CHAT_IDS
ALLOWED_CHAT_ID=

# ─── Voice (STT via Groq Whisper, free tier) ──────────────────────────────

# Get a key at https://console.groq.com (free, generous limits).
# Without this, voice notes will be rejected with a friendly message.
GROQ_API_KEY=

# ─── Optional ─────────────────────────────────────────────────────────────

# Log verbosity: trace | debug | info | warn | error
LOG_LEVEL=info

# Set to 'production' to disable pino-pretty and emit JSON logs instead.
# NODE_ENV=production
